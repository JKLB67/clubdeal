generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model Tenant {
  id               String          @id @default(uuid())
  slug             String          @unique
  subdomain        String          @unique
  name             String
  logoUrl          String?
  primaryColor     String          @default("#1a56db")
  secondaryColor   String          @default("#e3a008")
  status           TenantStatus    @default(ACTIVE)
  subscriptionPlan String          @default("starter")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  settings          TenantSettings?
  users             User[]
  projects          Project[]
  documentTemplates DocumentTemplate[]
  investments       Investment[]
  webhookEvents     WebhookEvent[]
}

model TenantSettings {
  id                String         @id @default(uuid())
  tenantId          String         @unique
  tenant            Tenant         @relation(fields: [tenantId], references: [id])

  pspProvider       PspProvider?
  pspClientIdEnc    String?
  pspApiKeyEnc      String?

  esignProvider     EsignProvider?
  esignApiKeyEnc    String?
  esignAccountIdEnc String?

  updatedAt         DateTime       @updatedAt
}

// ─────────────────────────────────────────────
// UTILISATEURS
// ─────────────────────────────────────────────

model User {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])

  email        String
  passwordHash String
  role         UserRole    @default(INVESTOR)
  profileType  ProfileType @default(PHYSICAL)
  statusKyc    KycStatus   @default(NOT_INITIATED)
  isPep        Boolean     @default(false)
  isSuspended  Boolean     @default(false)
  pspUserId    String?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  physicalProfile UserPhysicalProfile?
  legalProfile    UserLegalProfile?
  investments     Investment[]
  favorites       ProjectFavorite[]
  alerts          ProjectAlert[]

  @@unique([tenantId, email])
}

model UserPhysicalProfile {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])

  firstName    String
  lastName     String
  birthDate    DateTime?
  birthPlace   String?
  birthCountry String?
  nationality  String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  city         String?
  country      String?
}

model UserLegalProfile {
  id                    String  @id @default(uuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id])

  companyName           String
  legalForm             String?
  siren                 String?
  siret                 String?
  registeredAddress     String?
  legalRepresentativeId String?

  ubos                  Ubo[]
}

model Ubo {
  id               String           @id @default(uuid())
  legalProfileId   String
  legalProfile     UserLegalProfile @relation(fields: [legalProfileId], references: [id])

  firstName        String
  lastName         String
  birthDate        DateTime?
  nationality      String?
  address          String?
  ownershipPercent Decimal          @db.Decimal(5, 2)
}

// ─────────────────────────────────────────────
// PROJETS IMMOBILIERS
// ─────────────────────────────────────────────

model Project {
  id                       String        @id @default(uuid())
  tenantId                 String
  tenant                   Tenant        @relation(fields: [tenantId], references: [id])

  name                     String
  address                  String
  description              String?
  collectionGoal           BigInt
  collectedAmount          BigInt        @default(0)
  annualYield              Decimal       @db.Decimal(5, 2)
  durationMonths           Int
  precommercialisationRate Decimal?      @db.Decimal(5, 2)
  status                   ProjectStatus @default(DRAFT)

  minInvestment            BigInt?
  openingDate              DateTime?
  closingDate              DateTime?

  pspWalletId              String?
  virtualIban              String?

  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  photos         ProjectPhoto[]
  documents      ProjectDocument[]
  investments    Investment[]
  favorites      ProjectFavorite[]
  alerts         ProjectAlert[]
  contractConfig ContractConfig?
}

model ProjectPhoto {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  url        String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model ProjectDocument {
  id         String              @id @default(uuid())
  projectId  String
  project    Project             @relation(fields: [projectId], references: [id])
  name       String
  label      String?
  url        String
  type       ProjectDocumentType @default(OTHER)
  orderIndex Int                 @default(0)
  createdAt  DateTime            @default(now())
}

model ProjectFavorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model ProjectAlert {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  type      AlertType
  createdAt DateTime  @default(now())

  @@unique([userId, projectId, type])
}

enum AlertType {
  DOCUMENT_CHANGE
  COLLECTION_START
}

// ─────────────────────────────────────────────
// TEMPLATES DE DOCUMENTS
// ─────────────────────────────────────────────

model DocumentTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  templateUrl String
  variables   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  investments Investment[]
}

// ─────────────────────────────────────────────
// INVESTISSEMENTS
// ─────────────────────────────────────────────

model Investment {
  id        String           @id @default(uuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  projectId String
  project   Project          @relation(fields: [projectId], references: [id])
  templateId String?
  template  DocumentTemplate? @relation(fields: [templateId], references: [id])

  amount    BigInt
  status    InvestmentStatus @default(PENDING_SIGNATURE)

  signedDocumentUrl String?
  esignRequestId    String?
  esignSignedAt     DateTime?

  bulletinSignedAt        DateTime?
  contratInvestorSignedAt DateTime?
  contratEmitterSignedAt  DateTime?

  rejectionReason   String?
  rejectedAt        DateTime?

  pspTransactionId  String?
  confirmedAt       DateTime?

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// ─────────────────────────────────────────────
// ENTITÉ ÉMETTRICE (profil société du tenant)
// ─────────────────────────────────────────────

model TenantEntity {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  name                String   @default("")
  legalForm           String   @default("SAS")
  capital             Int      @default(1000)
  address             String   @default("")
  rcsCity             String   @default("")
  rcsNumber           String   @default("")
  representative      String   @default("")
  representativeTitle String   @default("Directeur Général")
  email               String?
  signatureCity       String   @default("Strasbourg")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─────────────────────────────────────────────
// CONFIGURATION DES CONTRATS PAR PROJET
// ─────────────────────────────────────────────

model ContractConfig {
  id                        String   @id @default(uuid())
  projectId                 String   @unique
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  priorityRank              Int      @default(1)
  minGuaranteedRate         Decimal  @default(6)  @db.Decimal(5, 2)
  guaranteedPeriodMonths    Int      @default(3)
  monthlyComplementaryRate  Decimal  @default(2)  @db.Decimal(5, 2)
  contractualCapRate        Decimal  @default(22) @db.Decimal(5, 2)
  propertyDescription       String?
  massRepresentative        String   @default("")
  competentCourt            String   @default("Strasbourg")
  earlyRepaymentNoticeDays  Int      @default(7)
  latePaymentPenaltyPoints  Int      @default(5)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ─────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────

model WebhookEvent {
  id              String          @id @default(uuid())
  tenantId        String?
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  provider        WebhookProvider
  externalEventId String          @unique
  eventType       String
  payload         Json
  status          WebhookStatus   @default(RECEIVED)
  createdAt       DateTime        @default(now())
  processedAt     DateTime?
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INVESTOR
}

enum ProfileType {
  PHYSICAL
  LEGAL
}

enum KycStatus {
  NOT_INITIATED
  PENDING
  VALIDATED
  REFUSED
}

enum PspProvider {
  MANGOPAY
  LEMONWAY
}

enum EsignProvider {
  YOUSIGN
  DOCUSIGN
  OODRIDE
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  FUNDED
  CLOSED
}

enum ProjectDocumentType {
  PERMIT
  COMPROMISE
  OTHER
}

enum InvestmentStatus {
  PENDING_SIGNATURE
  PENDING_COSIGN
  PENDING_PAYMENT
  CONFIRMED
  FAILED
  CANCELLED
  REJECTED
}

enum WebhookProvider {
  MANGOPAY
  LEMONWAY
  YOUSIGN
  DOCUSIGN
  OODRIDE
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}
